{
  "redirects": [
    { "source": "/contato", "destination": "/#cotacao", "permanent": true },
    { "source": "/contato/", "destination": "/#cotacao", "permanent": true },
    { "source": "/seja-nosso-cliente", "destination": "/#cotacao", "permanent": true },
    { "source": "/seja-nosso-cliente/", "destination": "/#cotacao", "permanent": true },
    { "source": "/sobre-nos", "destination": "/sobre", "permanent": true },
    { "source": "/sobre-nos/", "destination": "/sobre", "permanent": true },
    { "source": "/instituto-bedin", "destination": "/sobre", "permanent": true },
    { "source": "/instituto-bedin/", "destination": "/sobre", "permanent": true },
    { "source": "/blog", "destination": "https://blog.bedinrepresentacao.com.br", "permanent": false },
    { "source": "/blog/:path*", "destination": "https://blog.bedinrepresentacao.com.br/blog/:path*", "permanent": false }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
